{
  "private": true,
  "name": "@axonivy/log-view-root",
  "engines": {
    "node": ">=20.19.0"
  },
  "volta": {
    "node": "24.14.1"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "check": "pnpm run type && (pnpm run lint:ci || true) && pnpm run test:ci && pnpm run i18n:ci",
    "clean": "pnpm run -r clean",
    "build": "tsc --build",
    "package": "pnpm run -r package",
    "build:clean": "pnpm run -r build:clean",
    "type": "pnpm run -r type",
    "lint": "eslint",
    "lint:ci": "eslint -o eslint.xml -f checkstyle",
    "lint:fix": "eslint --fix",
    "lint:inspect": "eslint --inspect-config",
    "i18n": "pnpm run -r i18n",
    "i18n:ci": "pnpm run -r i18n:ci",
    "protocol": "pnpm run --filter @axonivy/log-view-protocol",
    "dev": "pnpm run --filter @axonivy/log-view-standalone dev",
    "test": "pnpm run --filter @axonivy/log-view test",
    "test:ci": "pnpm run --filter @axonivy/log-view test:ci",
    "webtest": "pnpm run -r webtest --",
    "update:axonivy:next": "npx --yes npm-check-updates @axonivy* -w -c 0 -t semver -u",
    "raise:version": "lerna version --no-git-tag-version --no-push --ignore-scripts --exact --yes",
    "publish:next": "lerna publish --exact --canary --preid next --tag-version-prefix beta --pre-dist-tag next --no-git-tag-version --no-push --ignore-scripts --yes"
  },
  "devDependencies": {
    "@axonivy/eslint-config": "14.0.0-next.1125.e82f52e",
    "@axonivy/prettier-config": "14.0.0-next.1125.e82f52e",
    "@axonivy/ts-config": "14.0.0-next.1125.e82f52e",
    "@lerna-lite/cli": "^5.2.2",
    "@lerna-lite/publish": "^5.2.2",
    "@lerna-lite/version": "^5.2.2",
    "@types/node": "^24.12.4",
    "rimraf": "^6.1.3",
    "tailwindcss": "^4.3.0",
    "typescript": "6.0.3"
  },
  "prettier": "@axonivy/prettier-config"
}
